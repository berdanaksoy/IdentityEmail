@model IdentityEmail.Entities.Message

@{
    bool isDraftMode = ViewBag.DraftMessageId != null && (int)ViewBag.DraftMessageId > 0;
}

@section Styles {
<style>
    .compose-card { background:#fff; border-radius:8px; box-shadow:0 1px 4px rgba(0,0,0,.08); margin:16px; }
    .compose-header { padding:16px 24px; border-bottom:1px solid #f0e0e8; display:flex; align-items:center; justify-content:space-between; }
    .compose-header h5 { margin:0; color:#333; font-weight:600; }
    .compose-field { display:flex; align-items:center; padding:12px 24px; border-bottom:1px solid #f5f5f5; gap:12px; }
    .compose-field label { width:60px; color:#888; font-size:13px; flex-shrink:0; margin:0; }
    .compose-field input { flex:1; border:none; outline:none; font-size:14px; color:#333; background:transparent; }
    .compose-field input::placeholder { color:#bbb; }
    .compose-body { padding:0 24px 24px; }
    .action-btn { border:1px solid #e0e0e0; background:#fff; border-radius:6px; padding:6px 14px; font-size:13px; cursor:pointer; transition:all .2s; display:inline-flex; align-items:center; gap:6px; }
    .action-btn:hover { background:#f5f5f5; text-decoration:none; color:inherit; }
    .action-btn.primary { background:#e85d8e; border-color:#e85d8e; color:#fff; }
    .action-btn.primary:hover { background:#d94b7f; }
    .receiver-suggestions { position:absolute; background:#fff; border:1px solid #f0d0e0; border-radius:6px; box-shadow:0 4px 12px rgba(0,0,0,.1); z-index:100; max-height:200px; overflow-y:auto; min-width:280px; }
    .receiver-suggestions .suggestion-item { display:flex; align-items:center; gap:10px; padding:8px 14px; cursor:pointer; font-size:13px; transition:background .15s; }
    .receiver-suggestions .suggestion-item:hover { background:#fff0f7; }
    .receiver-suggestions .suggestion-item img { width:30px; height:30px; border-radius:50%; object-fit:cover; }
    .receiver-suggestions .suggestion-name { font-weight:500; color:#333; }
    .receiver-suggestions .suggestion-email { color:#aaa; font-size:12px; }
</style>
}

<!-- Üst Bar -->
<div class="p-15 d-flex align-items-center" style="gap:8px; border-bottom:1px solid #f5f5f5;">
    <a href="/Message/Inbox?folder=@(isDraftMode ? "draft" : "inbox")" class="action-btn">
        <i class="fa fa-arrow-left"></i> Geri
    </a>
    <h6 class="mb-0 ml-2" style="color:#555;">
        @(isDraftMode ? "Taslağı Düzenle" : "Yeni Mesaj")
    </h6>
</div>

<div class="compose-card">
    <div class="compose-header">
        <h5>
            <i class="fa fa-pencil mr-2" style="color:#e85d8e;"></i>
            @(isDraftMode ? "Taslağı Düzenle" : "Yeni Mesaj Oluştur")
        </h5>
    </div>

    <!-- Alıcı -->
    <div class="compose-field" style="position:relative;">
        <label>Kime</label>
        <input type="text" id="receiverEmail"
               value="@(isDraftMode ? Model?.ReceiverEmail : "")"
               placeholder="Alıcı e-posta adresi..." autocomplete="off">
        <div id="receiverSuggestions" class="receiver-suggestions"
             style="display:none; position:absolute; top:100%; left:80px;"></div>
    </div>

    <!-- Konu -->
    <div class="compose-field">
        <label>Konu</label>
        <input type="text" id="subject"
               value="@(isDraftMode ? Model?.Subject : "")"
               placeholder="Mesajın konusu...">
    </div>

    <!-- İçerik -->
    <div class="compose-body mt-3">
        <textarea id="messageEditor"></textarea>
    </div>
</div>

<!-- Alt Butonlar -->
<div class="d-flex align-items-center p-15" style="gap:8px; margin:0 16px;">
    <button class="action-btn primary" id="sendBtn">
        <i class="fa fa-paper-plane"></i> Gönder
    </button>
    <button class="action-btn" id="draftBtn">
        <i class="fa fa-save"></i> @(isDraftMode ? "Taslağı Güncelle" : "Taslak Olarak Kaydet")
    </button>
</div>

@section Scripts {
<script>
    var isDraftMode  = @(isDraftMode ? "true" : "false");
    var draftId      = @(isDraftMode ? (int)ViewBag.DraftMessageId : 0);
    var draftContent = @Html.Raw(isDraftMode ? System.Text.Json.JsonSerializer.Serialize(Model?.MessageDetail ?? "") : "\"\"");
</script>
<script>
    $(document).ready(function () {

        // Summernote
        $('#messageEditor').summernote({
            placeholder: 'Mesajınızı buraya yazın...',
            tabsize: 2,
            height: 300,
            toolbar: [
                ['style',  ['bold', 'italic', 'underline', 'strikethrough']],
                ['font',   ['fontname', 'fontsize']],
                ['color',  ['color']],
                ['para',   ['ul', 'ol', 'paragraph']],
                ['insert', ['link']],
                ['view',   ['fullscreen']]
            ],
            fontNames: ['Arial', 'Arial Black', 'Comic Sans MS', 'Courier New', 'Georgia', 'Tahoma', 'Times New Roman', 'Verdana'],
            fontSizes: ['8', '9', '10', '11', '12', '14', '16', '18', '24', '36']
        });

        if (isDraftMode && draftContent) {
            $('#messageEditor').summernote('code', draftContent);
        }

        setTimeout(function () {
            var dialog = $('.link-dialog');
            dialog.find('label').each(function () {
                var t = $(this).text().trim();
                if (t.indexOf('Text to display') !== -1) $(this).text('Görüntülenecek metin');
                if (t.indexOf('URL') !== -1) $(this).text('Bağlantı adresi');
            });
            dialog.find('.modal-title').text('Bağlantı Ekle');
            dialog.find('.note-link-btn').text('Ekle');
        }, 500);

        $(document).on('shown.bs.modal', function () {
            $('.modal:visible')
                .find('label[for="sn-checkbox-open-in-new-window"]')
                .closest('.checkbox').remove();
        });

        // Alıcı otomatik tamamlama
        var searchTimeout;
        $('#receiverEmail').on('input', function () {
            clearTimeout(searchTimeout);
            var val = $(this).val().trim();
            if (val.length < 2) { $('#receiverSuggestions').hide(); return; }
            searchTimeout = setTimeout(function () {
                $.get('/Message/SearchUsers', { query: val })
                    .done(function (res) {
                        var list = $('#receiverSuggestions');
                        list.empty();
                        if (!res || res.length === 0) { list.hide(); return; }
                        res.forEach(function (u) {
                            list.append(
                                '<div class="suggestion-item" data-email="' + u.email + '">' +
                                '<img src="' + (u.imageUrl || '') + '" alt="">' +
                                '<div><div class="suggestion-name">' + u.fullname + '</div>' +
                                '<div class="suggestion-email">' + u.email + '</div></div>' +
                                '</div>'
                            );
                        });
                        list.show();
                    });
            }, 300);
        });

        $(document).on('click', '.suggestion-item', function () {
            $('#receiverEmail').val($(this).data('email'));
            $('#receiverSuggestions').hide();
        });

        $(document).on('click', function (e) {
            if (!$(e.target).closest('.compose-field').length)
                $('#receiverSuggestions').hide();
        });

        // Gönder
        $('#sendBtn').on('click', function () {
            var receiver = $('#receiverEmail').val().trim();
            var subject  = $('#subject').val().trim();
            var content  = $('#messageEditor').summernote('code');

            if (!receiver) { alert('Alıcı e-posta adresi boş olamaz.'); return; }
            if (!subject)  { alert('Konu boş olamaz.'); return; }
            if (!content || content === '<p><br></p>') { alert('Mesaj içeriği boş olamaz.'); return; }

            $.post('/Message/CreateMessage', {
                receiverEmail:  receiver,
                subject:        subject,
                messageDetail:  content,
                draftMessageId: draftId
            }).done(function (res) {
                if (res.success) {
                    alert('Mesaj gönderildi.');
                    window.location.href = '/Message/Inbox?folder=sent';
                } else {
                    alert(res.message || 'Hata oluştu.');
                }
            }).fail(function () {
                alert('Sunucu hatası.');
            });
        });

        // Taslak kaydet / güncelle
        $('#draftBtn').on('click', function () {
            var receiver = $('#receiverEmail').val().trim();
            var subject  = $('#subject').val().trim();
            var content  = $('#messageEditor').summernote('code');

            $.post('/Message/SaveDraft', {
                receiverEmail:  receiver,
                subject:        subject,
                messageDetail:  content,
                draftMessageId: draftId
            }).done(function (res) {
                if (res.success) {
                    alert(isDraftMode ? 'Taslak güncellendi.' : 'Taslak kaydedildi.');
                    window.location.href = '/Message/Inbox?folder=draft';
                } else {
                    alert(res.message || 'Hata oluştu.');
                }
            });
        });
    });
</script>
}